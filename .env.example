# Copy this file to .env before first use.
# Provide either AK/SK or username/password.
# JMS_ORG_ID can be left empty at first and later written by select-org.
JMS_API_URL="https://jump.example.com"
JMS_ACCESS_KEY_ID="your-access-key-id"
JMS_ACCESS_KEY_SECRET="your-access-key-secret"
# JMS_USERNAME="your-username"
# JMS_PASSWORD="your-password"
# JMS_ORG_ID=""
# JMS_TIMEOUT="30"
# JMS_VERIFY_TLS="false"
